			"text": "    new_build = None\n    if not self.isBuilt:\n        new_id = service.build_from(self)\n        update_docker_image_id(self, new_id)\n        \n    else:\n        new_build = rebuild_and_replace(self)\n\n    return (self, new_build)",
			"rawText": "    new_build = None\n    if not self.isBuilt:\n        new_id = service.build_from(self)\n        update_docker_image_id(self, new_id)\n        \n    else:\n        new_build = rebuild_and_replace(self)\n\n    return (self, new_build)",
			"fontSize": 20,
