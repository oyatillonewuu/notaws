			"updated": 1777041284438,
			"locked": false,
			"text": "if tag changed:\n    self.tag = new_tag\n\nif dockerfile_code changed or foce_rebuild:\n    update_dockerfile_code_if_changed()\n    rebuild_and_replace(self)\n   \nself.save()",
			"rawText": "if tag changed:\n    self.tag = new_tag\n\nif dockerfile_code changed or foce_rebuild:\n    update_dockerfile_code_if_changed()\n    rebuild_and_replace(self)\n   \nself.save()",
