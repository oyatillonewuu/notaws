			"updated": 1777280722704,
			"locked": false,
			"text": "create_instance(image, ram, cpu, storage):\n    # Assumes active_build is BUILT.\n\n    new_instance = Instance(\n        image=image,\n        build_in_use=image.active_build,\n        ram=ram,\n        cpu=cpu,\n        storage\n    )\n\n    new_instance.save()\n\n    new_instace.docker_container_id = schedule_container_creation_from(new_instance)",
			"rawText": "create_instance(image, ram, cpu, storage):\n    # Assumes active_build is BUILT.\n\n    new_instance = Instance(\n        image=image,\n        build_in_use=image.active_build,\n        ram=ram,\n        cpu=cpu,\n        storage\n    )\n\n    new_instance.save()\n\n    new_instace.docker_container_id = schedule_container_creation_from(new_instance)",
			"fontSize": 16.677457571990313,
			"fontFamily": 8,
			"textAlign": "left",
			"verticalAlign": "middle",
			"containerId": "N9Krte6A",
			"originalText": "create_instance(image, ram, cpu, storage):\n    # Assumes active_build is BUILT.\n\n    new_instance = Instance(\n        image=image,\n        build_in_use=image.active_build,\n        ram=ram,\n        cpu=cpu,\n        storage\n    )\n\n    new_instance.save()\n\n    new_instace.docker_container_id = schedule_container_creation_from(new_instance)",
			"autoResize": true,
