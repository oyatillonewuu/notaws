		{
			"id": "zCUNAAb3",
			"type": "text",
			"x": 1207.6259500375725,
			"y": 3545.483267475517,
			"width": 3011.182423354542,
			"height": 1751.305124498691,
			"angle": 0,
			"strokeColor": "#1e1e1e",
			"backgroundColor": "transparent",
			"fillStyle": "solid",
			"strokeWidth": 2,
			"strokeStyle": "solid",
			"roughness": 0,
			"opacity": 100,
			"groupIds": [],
			"frameId": null,
			"index": "b29",
			"roundness": null,
			"seed": 1342337992,
			"version": 1176,
			"versionNonce": 1643649016,
			"isDeleted": false,
			"boundElements": [],
			"updated": 1777284527445,
			"locked": false,
			"text": "notaws (django project)\n    docker_ops/   (docker client + docker primitive wrappers)\n        client.py\n        image.py\n        container.py\n    notaws/\n    ec2/    (we use unconventional multi-app in app structure)\n        urls.py   (url aggregator)\n        models.py (imports all models defined in sub-apps)\n        apps/\n            image/\n                models.py\n                views.py\n                urls.py\n                service.py  (defines service functions)\n                exceptions.py (defines exception handlers both for http errors and application exceptions)\n            image_build/\n                models.py\n                views.py\n                urls.py\n                service.py\n            instance/\n                ...\n            user_dashboard/\n                ...\n    s3/\n        (the same as with ec2)\n        ...\n",
			"rawText": "notaws (django project)\n    docker_ops/   (docker client + docker primitive wrappers)\n        client.py\n        image.py\n        container.py\n    notaws/\n    ec2/    (we use unconventional multi-app in app structure)\n        urls.py   (url aggregator)\n        models.py (imports all models defined in sub-apps)\n        apps/\n            image/\n                models.py\n                views.py\n                urls.py\n                service.py  (defines service functions)\n                exceptions.py (defines exception handlers both for http errors and application exceptions)\n            image_build/\n                models.py\n                views.py\n                urls.py\n                service.py\n            instance/\n                ...\n            user_dashboard/\n                ...\n    s3/\n        (the same as with ec2)\n        ...\n",
			"fontSize": 48.311865503412164,
			"fontFamily": 8,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "notaws (django project)\n    docker_ops/   (docker client + docker primitive wrappers)\n        client.py\n        image.py\n        container.py\n    notaws/\n    ec2/    (we use unconventional multi-app in app structure)\n        urls.py   (url aggregator)\n        models.py (imports all models defined in sub-apps)\n        apps/\n            image/\n                models.py\n                views.py\n                urls.py\n                service.py  (defines service functions)\n                exceptions.py (defines exception handlers both for http errors and application exceptions)\n            image_build/\n                models.py\n                views.py\n                urls.py\n                service.py\n            instance/\n                ...\n            user_dashboard/\n                ...\n    s3/\n        (the same as with ec2)\n        ...\n",
			"autoResize": false,
			"lineHeight": 1.25,
			"hasTextLink": false,
			"link": null
		},
