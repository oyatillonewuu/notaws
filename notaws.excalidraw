			"boundElements": [],
			"updated": 1777041541899,
			"locked": false,
			"text": "create_build_from(MIB_entity):\n    new_MIB = create_cope(MIB_entity)\n    new_MIB.save()\n    image_id = build_from(new_MIB)\n    new_MIB.docker_image_id = image_id\n    return new_MIB\n\nbuild_from(MI_entity)\n    tag = MI_entity.tag\n    dockerfile_code = MI_entity.dockerfile_code\n    image, logs = docker.build(tag, File(dockerfile_code, no_cache=True)\n    return image.id\n\nrebuild_and_replace(old_build):\n    new_build = create_build_from(olb_build)\n    old_build.deprecated = True\n    old_build.save()\n    updte_image_references(old_build=old_build, new_build=new_build)\n    return new_build\n   \nupdate_docker_image_id(build, new_id):\n    build.docker_image_id = new_id\n    build.save() \n\nschedule_remove_if_exists_from(MI_entity)\n    jobs.add(remove(MI_entity.id))\n\ndeprecated_build_clean_up_job()\n    -- system job that cleans up deprecated builds which are not\n    being used anymore.",
			"rawText": "create_build_from(MIB_entity):\n    new_MIB = create_cope(MIB_entity)\n    new_MIB.save()\n    image_id = build_from(new_MIB)\n    new_MIB.docker_image_id = image_id\n    return new_MIB\n\nbuild_from(MI_entity)\n    tag = MI_entity.tag\n    dockerfile_code = MI_entity.dockerfile_code\n    image, logs = docker.build(tag, File(dockerfile_code, no_cache=True)\n    return image.id\n\nrebuild_and_replace(old_build):\n    new_build = create_build_from(olb_build)\n    old_build.deprecated = True\n    old_build.save()\n    updte_image_references(old_build=old_build, new_build=new_build)\n    return new_build\n   \nupdate_docker_image_id(build, new_id):\n    build.docker_image_id = new_id\n    build.save() \n\nschedule_remove_if_exists_from(MI_entity)\n    jobs.add(remove(MI_entity.id))\n\ndeprecated_build_clean_up_job()\n    -- system job that cleans up deprecated builds which are not\n    being used anymore.",
			"fontSize": 35.378296508805974,
			"fontFamily": 5,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "create_build_from(MIB_entity):\n    new_MIB = create_cope(MIB_entity)\n    new_MIB.save()\n    image_id = build_from(new_MIB)\n    new_MIB.docker_image_id = image_id\n    return new_MIB\n\nbuild_from(MI_entity)\n    tag = MI_entity.tag\n    dockerfile_code = MI_entity.dockerfile_code\n    image, logs = docker.build(tag, File(dockerfile_code, no_cache=True)\n    return image.id\n\nrebuild_and_replace(old_build):\n    new_build = create_build_from(olb_build)\n    old_build.deprecated = True\n    old_build.save()\n    updte_image_references(old_build=old_build, new_build=new_build)\n    return new_build\n   \nupdate_docker_image_id(build, new_id):\n    build.docker_image_id = new_id\n    build.save() \n\nschedule_remove_if_exists_from(MI_entity)\n    jobs.add(remove(MI_entity.id))\n\ndeprecated_build_clean_up_job()\n    -- system job that cleans up deprecated builds which are not\n    being used anymore.",
			"autoResize": true,
			"lineHeight": 1.25,
			"hasTextLink": false,
			"link": null
		},
